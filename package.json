{
  "name": "paths-guard",
  "version": "0.1.0",
  "description": "GitHub Action that re-checks workflow path filters at runtime",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "all": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "github-action",
    "paths",
    "filter"
  ],
  "author": "Derek Prior",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/picomatch": "^4.0.3",
    "@vercel/ncc": "^0.38.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^6.0.0",
    "picomatch": "^4.0.0",
    "yaml": "^2.4.0"
  }
}
